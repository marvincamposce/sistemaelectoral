# Postgres (docker compose)
DATABASE_URL=postgresql://blockurna:blockurna@127.0.0.1:5432/blockurna

# Evidence source (TPE)
RPC_URL=http://127.0.0.1:8545
ELECTION_REGISTRY_ADDRESS=

# Actas firmadas (fuente local para contenido íntegro)
# Por defecto: packages/contracts/generated-output
ACTA_SOURCE_DIR=packages/contracts/generated-output

# Indexer settings
START_BLOCK=0
CONFIRMATIONS=0
BATCH_SIZE=2000
POLL_INTERVAL_MS=2000
